{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Smart Focus Tracker",
  "version": "2.3.0",
  "identifier": "com.zjz.tracker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Smart Focus Tracker",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "decorations": false,
        "backgroundColor": [248, 250, 252, 255]
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/128x128.png",
      "icons/32x32.png"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Jianzhe228/tracker/releases/latest/download/latest.json"
      ],
